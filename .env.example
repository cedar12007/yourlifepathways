# YourLifePathways Environment Configuration
# Copy this file to .env and update with your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
DATABASE_URL=postgresql://postgres.wiczpfjdffindqahmlsq:CedarTree1!dB@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Traffic Logging
TRAFFIC_LOGGING=no
TRAFFIC_LOGGING_LOCAL=no

# Redis Configuration (Optional)
redis_enabled=false
redis_url=your-redis-url
redis_token=your-redis-token

# Google reCAPTCHA
recaptcha_secret_key=your-recaptcha-secret-key

# Email Configuration (Gmail SMTP)
doar_ktovet=your-email@gmail.com
doar_sisma=your-app-password-here

# Notes:
# 1. SECRET_KEY: Generate a strong random key for Flask sessions
#    You can use: python -c "import secrets; print(secrets.token_hex(32))"
#
# 2. DATABASE_URL: For production, use PostgreSQL:
#    postgresql://user:password@host:port/database
#
# 3. TRAFFIC_LOGGING: Set to 'yes' to enable traffic logging
#    TRAFFIC_LOGGING_LOCAL: Set to 'yes' to log localhost traffic (development)
#
# 4. Redis: Enable for rate limiting on contact form submissions
#    redis_url: Your Redis instance URL
#    redis_token: Your Redis authentication token
#
# 5. recaptcha_secret_key: Get from https://www.google.com/recaptcha/admin
#    (You'll also need to update the site key in templates)
#
# 6. Gmail SMTP: Use App Password (not regular password)
#    Instructions: https://support.google.com/accounts/answer/185833
#    doar_ktovet = Gmail address
#    doar_sisma = App-specific password